[Unit]
Description=PI-Board Backend
After=network-online.target pipewire.service
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/piboard/backend
Environment=PATH=/home/pi/piboard/.venv/bin:/usr/bin:/bin
ExecStart=/home/pi/piboard/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
