# ============================================
# Ekip Assistant — Environment Variables
# Copy this file to .env and fill in your keys
# ============================================

# --- STT / TTS (OpenAI) ---
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Spotify ---
# Create an app at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
SPOTIFY_DEVICE_NAME=Devialet

# --- Weather ---
# Free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=
WEATHER_CITY=Paris
WEATHER_LAT=48.85
WEATHER_LON=2.35
WEATHER_LANG=fr
WEATHER_UNITS=metric

# --- UniFi Cameras (optional) ---
UNIFI_HOST=
UNIFI_USER=
UNIFI_PASS=

# --- Audio ---
PIPEWIRE_AIRPLAY_SINK=Devialet
RESPEAKER_DEVICE=hw:ReSpeaker,0

# --- Server ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- Admin ---
# Default credentials: admin / piboard
# Change the password from the admin panel after first login
